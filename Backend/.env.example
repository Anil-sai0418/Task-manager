# Database Configuration
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/dbname?retryWrites=true&w=majority&appName=Main

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here

# Resend Email Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_your_api_key_here

# Email Sender Configuration
# Use the verified sender email from your Resend account
# Default: onboarding@resend.dev (for testing)
# Production: your-domain@yourdomain.com (after verification)
RESEND_FROM_EMAIL=onboarding@resend.dev

# Frontend URL
# Used in email links and CORS configuration
FRONTEND_URL=http://localhost:5173
# Production: https://task-manager-anil.vercel.app

# Optional: For production deployment
NODE_ENV=development
PORT=8000
